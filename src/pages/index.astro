---
import Layout from '../layouts/Layout.astro'
---

<Layout title="bilomasti">
  <main class="max-w-2xl mx-auto px-6 py-20 space-y-24">

    <!-- Header -->
    <header>
      <p class="text-neutral-500 text-sm mb-1">bilal parvez</p>
      <h1 class="text-4xl font-bold text-white tracking-tight">bilomasti</h1>
      <p class="mt-4 text-neutral-400 leading-relaxed">
        alive human.
      </p>
    </header>

    <!-- About -->
    <section id="about">
      <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-4">about</h2>
      <p class="text-neutral-300 leading-relaxed">
        i exist.
      </p>
    </section>

    <!-- Projects -->
    <section id="projects">
      <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-6">projects</h2>
      <ul class="space-y-6">
        <li>
          <a href="#" class="group block">
            <div class="flex items-baseline justify-between">
              <span class="text-white group-hover:text-neutral-300 transition-colors">project name</span>
              <span class="text-neutral-600 text-xs">2025</span>
            </div>
            <p class="text-neutral-400 text-sm mt-1">short description of what this project does.</p>
          </a>
        </li>
        <li>
          <a href="#" class="group block">
            <div class="flex items-baseline justify-between">
              <span class="text-white group-hover:text-neutral-300 transition-colors">another project</span>
              <span class="text-neutral-600 text-xs">2024</span>
            </div>
            <p class="text-neutral-400 text-sm mt-1">short description of what this project does.</p>
          </a>
        </li>
      </ul>
    </section>

    <!-- Interests -->
    <section id="interests">
      <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-4">interests</h2>
      <div class="flex flex-wrap gap-2">
        {['programming', 'music', 'reading', 'gaming', 'tech'].map(item => (
          <span class="px-3 py-1 bg-neutral-900 text-neutral-300 text-sm rounded border border-neutral-800">
            {item}
          </span>
        ))}
      </div>
    </section>

    <!-- Contact -->
    <section id="contact">
      <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-4">contact</h2>
      <ul class="space-y-2 text-sm">
        <li>
          <a href="mailto:your@email.com" class="text-neutral-300 hover:text-white transition-colors">
            email →
          </a>
        </li>
        <li>
          <a href="https://github.com/" class="text-neutral-300 hover:text-white transition-colors">
            github →
          </a>
        </li>
      </ul>
    </section>

    <!-- Family Wiki -->
    <section id="family-wiki">
      <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-4">family wiki</h2>
      <a
        href="https://wiki.bilomasti.pk"
        class="inline-block px-4 py-2 bg-neutral-900 border border-neutral-800 text-neutral-300 text-sm hover:border-neutral-600 hover:text-white transition-colors"
      >
        private — enter →
      </a>
    </section>

    <!-- Footer -->
    <footer class="pt-8 border-t border-neutral-900 text-neutral-600 text-xs">
      bilomasti · {new Date().getFullYear()}
    </footer>

  </main>
</Layout>
